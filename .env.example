# Copy this file to ".env" for LOCAL testing with `netlify dev`.
# Never commit your real .env (it's already in .gitignore).

# AI assistant — free key from https://aistudio.google.com (new keys start with AQ.)
GEMINI_API_KEY=AQ.your-gemini-key-here

# News feed — free token from https://cryptopanic.com/developers/api/keys
CRYPTOPANIC_TOKEN=your-cryptopanic-token-here
